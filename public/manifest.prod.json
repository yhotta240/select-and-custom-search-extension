{
  "manifest_version": 3,
  "name": "選択＆カスタム検索 - Select & Custom Search",
  "short_name": "選択＆カスタム検索",
  "version": "1.5.0",
  "description": "選択したテキストを好みのサイトで素早く効率的に検索！あなたの探している情報にすぐアクセスできる便利な拡張機能です．",
  "icons": {
    "48": "icons/icon.png"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}